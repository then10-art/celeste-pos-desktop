{
  "name": "celeste-pos-desktop",
  "version": "1.3.5",
  "description": "Celeste POS - Desktop Application for Windows",
  "main": "src/main.js",
  "author": "Celeste POS",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:x64": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --x64",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "@node-escpos/core": "^0.6.0",
    "@node-escpos/network-adapter": "^0.0.1",
    "@node-escpos/serialport-adapter": "^1.0.0",
    "@node-escpos/usb-adapter": "^0.3.1",
    "axios": "^1.6.7",
    "better-sqlite3": "^9.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^5.3.0",
    "node-hid": "^2.1.2",
    "serialport": "^10.5.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.celestepos.desktop",
    "productName": "Celeste POS",
    "copyright": "Copyright \u00a9 2024 Celeste POS",
    "icon": "assets/icon.ico",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/@serialport/**",
      "node_modules/node-hid/**",
      "node_modules/usb/**",
      "node_modules/@node-escpos/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Celeste POS",
      "runAfterFinish": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "webapp/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "webapp",
        "to": "webapp",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://celestepos.live/api/updates/"
    }
  }
}
